{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "redirects": [
    { "source": "/product", "destination": "/categories/number-plates", "permanent": true },
    { "source": "/plate-holders", "destination": "/categories/plate-holders", "permanent": true },
    { "source": "/keyrings", "destination": "/categories/keyrings", "permanent": true },
    { "source": "/gallery", "destination": "/", "permanent": true },
    { "source": "/collections/road-legal-number-plates", "destination": "/categories/number-plates", "permanent": true },
    { "source": "/collections/showplates", "destination": "/categories/number-plates", "permanent": true },
    { "source": "/collections/plate-holders", "destination": "/categories/plate-holders", "permanent": true },
    { "source": "/collections/keyrings", "destination": "/categories/keyrings", "permanent": true },
    { "source": "/collections/accessories", "destination": "/categories/accessories", "permanent": true },
    { "source": "/collections/car-hangings", "destination": "/categories/car-hangings", "permanent": true },
    { "source": "/collections/4d-laser-cut-house-signs", "destination": "/categories/house-plates", "permanent": true },
    { "source": "/collections/:path*", "destination": "/categories/number-plates", "permanent": true },
    { "source": "/products/:path*", "destination": "/builder/:path*", "permanent": true },
    { "source": "/pages/about-us", "destination": "/about", "permanent": true },
    { "source": "/pages/our-promise", "destination": "/about", "permanent": true },
    { "source": "/pages/bsau145e-rules", "destination": "/legal", "permanent": true },
    { "source": "/pages/submitting-required-documents", "destination": "/legal", "permanent": true },
    { "source": "/pages/:path*", "destination": "/legal", "permanent": true },
    { "source": "/blogs/:path*", "destination": "/about", "permanent": true }
  ],
  "rewrites": [
    { "source": "/cart", "destination": "https://3b4c31.myshopify.com/cart" },
    { "source": "/cart/:path*", "destination": "https://3b4c31.myshopify.com/cart/:path*" },
    { "source": "/checkouts/:path*", "destination": "https://3b4c31.myshopify.com/checkouts/:path*" },
    { "source": "/checkout/:path*", "destination": "https://3b4c31.myshopify.com/checkout/:path*" },
    { "source": "/wallets/:path*", "destination": "https://3b4c31.myshopify.com/wallets/:path*" },
    { "source": "/services/:path*", "destination": "https://3b4c31.myshopify.com/services/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
