{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "redirects": [
    { "source": "/collections/road-legal-number-plates", "destination": "/product", "permanent": true },
    { "source": "/collections/showplates", "destination": "/product", "permanent": true },
    { "source": "/collections/plate-holders", "destination": "/plate-holders", "permanent": true },
    { "source": "/collections/keyrings", "destination": "/keyrings", "permanent": true },
    { "source": "/collections/:path*", "destination": "/product", "permanent": true },
    { "source": "/products/:path*", "destination": "/product", "permanent": true },
    { "source": "/pages/about-us", "destination": "/about", "permanent": true },
    { "source": "/pages/our-promise", "destination": "/about", "permanent": true },
    { "source": "/pages/bsau145e-rules", "destination": "/legal", "permanent": true },
    { "source": "/pages/submitting-required-documents", "destination": "/legal", "permanent": true },
    { "source": "/pages/:path*", "destination": "/legal", "permanent": true },
    { "source": "/blogs/:path*", "destination": "/about", "permanent": true }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
